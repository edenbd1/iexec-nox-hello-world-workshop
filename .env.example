# Copy to .env and fill in. .env is git-ignored.

# Deployer private key (used only for Arbitrum Sepolia).
# DO NOT commit a real mainnet key here.
PRIVATE_KEY=0xabc...

# Optional: override the default Arbitrum Sepolia RPC.
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Optional: needed only for `npx hardhat verify`.
ARBISCAN_API_KEY=
